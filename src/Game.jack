        // Fila 4
        let map[80]=1;  let map[81]=0;  let map[82]=1;  let map[83]=1;
        let map[84]=1;  let map[85]=1;  let map[86]=1;  let map[87]=0;
        let map[88]=1;  let map[89]=1;  let map[90]=0;  let map[91]=1;
