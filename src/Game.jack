/**
 * Game.jack
 * Maze Intelligence - Motor principal del juego.
 *
 * Flujo completo en loop:
 *   1. Pantalla de inicio  → presiona ESPACIO para jugar
 *      (los ticks de espera = semilla del spawn del enemigo)
 *   2. Partida             → jugador se mueve, enemigo persigue por BFS
 *   3. Pantalla de fin     → presiona ESPACIO para volver al inicio
 *   Repite desde 1 indefinidamente.
 *
 * Estados de partida:
 *   0 = JUGANDO
 *   1 = GANASTE  (jugador llega a la meta)
 *   2 = GAME OVER (enemigo atrapa al jugador)
 *
 * Jugador: (1,1) — esquina superior izquierda del laberinto.
 * Meta:    (17,17) — callejón con una sola entrada.
 * Enemigo: spawn aleatorio fuera de filas 1-8 / cols 1-8.
 */
class Game {

    field Array  map;
    field int    cellW, cellH;
    field int    goalRow, goalCol;

    constructor Game new() {
        let cellW   = 25;
        let cellH   = 12;
        let goalRow = 17;
        let goalCol = 17;
        do buildMap();
        return this;
    }

    // ----------------------------------------------------------------
    // Pantalla de inicio.
    // Cuenta los ticks mientras el usuario espera y presiona ESPACIO.
    // Devuelve ese conteo como semilla para el spawn del enemigo.
    // ----------------------------------------------------------------
    method int showIntro() {
        var int ticks, key;
        let ticks = 0;
        let key   = 0;

        do Screen.clearScreen();
        do Output.moveCursor(5, 6);
        do Output.printString("===== MAZE INTELLIGENCE =====");
        do Output.moveCursor(8,  6);
        do Output.printString("Objetivo: llega a la meta (*)");
        do Output.moveCursor(9,  6);
        do Output.printString("El enemigo busca el camino mas");
        do Output.moveCursor(10, 6);
        do Output.printString("corto para atraparte.");
        do Output.moveCursor(12, 6);
        do Output.printString("Controles: flechas del teclado");
        do Output.moveCursor(15, 6);
        do Output.printString("Presiona ESPACIO para iniciar...");

        // Contar ticks hasta que el usuario presione ESPACIO (32)
        while (~(key = 32)) {
            let ticks = ticks + 1;
            do Sys.wait(50);
            let key = Keyboard.keyPressed();
        }

        // Esperar a que suelte ESPACIO antes de arrancar
        while (~(Keyboard.keyPressed() = 0)) {
            do Sys.wait(30);
        }

        return ticks;
    }

    // ----------------------------------------------------------------
    // Pantalla de fin. Muestra resultado y espera ESPACIO para reiniciar.
    // ----------------------------------------------------------------
    method void showEnd(int result) {
        do Screen.clearScreen();
        do Output.moveCursor(8, 10);

        if (result = 1) {
            do Output.printString("**** GANASTE! ****");
            do Output.moveCursor(10, 6);
            do Output.printString("Lograste llegar a la meta.");
        } else {
            do Output.printString("**** GAME OVER ****");
            do Output.moveCursor(10, 6);
            do Output.printString("El enemigo te atrapo.");
        }

        do Output.moveCursor(13, 6);
        do Output.printString("Presiona ESPACIO para volver a jugar...");

        // Esperar ESPACIO (32)
        while (~(Keyboard.keyPressed() = 32)) {
            do Sys.wait(50);
        }
        while (~(Keyboard.keyPressed() = 0)) {
            do Sys.wait(30);
        }
        return;
    }

    // ----------------------------------------------------------------
    // Una partida completa. Devuelve 1=ganó, 2=perdió.
    // ----------------------------------------------------------------
    method int playRound(int seed) {
        var Player player;
        var Enemy  enemy;
        var int    state, key, blinkCount;
        var boolean goalVisible;

        let state       = 0;
        let blinkCount  = 0;
        let goalVisible = true;

        let player = Player.new(1, 1, cellW, cellH);
        let enemy  = Enemy.new(cellW, cellH, 5, map, seed);

        do Screen.clearScreen();
        do drawMap();
        do drawGoal(true);
        do player.draw();
        do enemy.draw();

        do Output.moveCursor(22, 0);
        do Output.printString("Flechas=mover  |  (*) = meta  |  ESC=salir");

        while (state = 0) {
            let key = Keyboard.keyPressed();

            // ESC termina la partida como derrota
            if (key = 140) { let state = 2; }

            if (~(key = 0)) {
                do player.move(key, map);
            }

            do enemy.move(player.getRow(), player.getCol(), map);

            // Parpadeo de la meta
            let blinkCount = blinkCount + 1;
            if (blinkCount > 8) {
                let blinkCount  = 0;
                let goalVisible = ~goalVisible;
                do drawGoal(goalVisible);
            }

            // Chequear victoria
            if ((player.getRow() = goalRow) & (player.getCol() = goalCol)) {
                let state = 1;
            }

            // Chequear derrota
            if ((enemy.getRow() = player.getRow()) & (enemy.getCol() = player.getCol())) {
                let state = 2;
            }

            do Sys.wait(90);
        }

        do player.dispose();
        do enemy.dispose();

        return state;
    }

    // ----------------------------------------------------------------
    // Loop principal: intro → partida → fin → intro → ...
    // ----------------------------------------------------------------
    method void run() {
        var int seed, result;

        while (true) {
            // 1. Pantalla de inicio — obtener semilla del tiempo de espera
            let seed = showIntro();

            // 2. Jugar una partida
            let result = playRound(seed);

            // 3. Pantalla de fin — ESPACIO para volver al inicio
            do showEnd(result);
        }

        return;
    }

    // ----------------------------------------------------------------
    // Dibuja el mapa completo
    // ----------------------------------------------------------------
    method void drawMap() {
        var int r, c, x1, y1, x2, y2;
        let r = 0;
        while (r < 20) {
            let c = 0;
            while (c < 20) {
                let x1 = c * cellW;
                let y1 = r * cellH;
                let x2 = x1 + cellW;
                let y2 = y1 + cellH;
                if (map[(r * 20) + c] = 1) {
                    do Screen.setColor(true);
                } else {
                    do Screen.setColor(false);
                }
                do Screen.drawRectangle(x1, y1, x2, y2);
                let c = c + 1;
            }
            let r = r + 1;
        }
        return;
    }

    // ----------------------------------------------------------------
    // Dibuja/borra la meta parpadeante en (17,17)
    // ----------------------------------------------------------------
    method void drawGoal(boolean visible) {
        var int x1, y1, x2, y2;
        let x1 = goalCol * cellW;
        let y1 = goalRow * cellH;
        let x2 = x1 + cellW - 1;
        let y2 = y1 + cellH - 1;
        if (visible) {
            do Screen.setColor(true);
            do Screen.drawRectangle(x1, y1, x2, y2);
            do Screen.setColor(false);
            do Screen.drawRectangle(x1 + 5, y1 + 3, x2 - 5, y2 - 3);
        } else {
            do Screen.setColor(false);
            do Screen.drawRectangle(x1, y1, x2, y2);
        }
        return;
    }

    // ----------------------------------------------------------------
    // Mapa 20x20 — 1=muro (negro), 0=camino (blanco)
    // ----------------------------------------------------------------
    method void buildMap() {
        let map = Array.new(400);

        // Fila 0
