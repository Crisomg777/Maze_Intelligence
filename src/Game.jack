        let map[116]=0; let map[117]=0; let map[118]=0; let map[119]=1;

        // Fila 6
        let map[120]=1; let map[121]=1; let map[122]=1; let map[123]=0;
        let map[124]=1; let map[125]=0; let map[126]=1; let map[127]=1;
        let map[128]=1; let map[129]=0; let map[130]=1; let map[131]=1;
        let map[132]=0; let map[133]=1; let map[134]=1; let map[135]=0;
        let map[136]=1; let map[137]=1; let map[138]=1; let map[139]=1;

        // Fila 7
        let map[140]=1; let map[141]=0; let map[142]=0; let map[143]=0;
        let map[144]=1; let map[145]=0; let map[146]=0; let map[147]=0;
        let map[148]=1; let map[149]=0; let map[150]=0; let map[151]=1;
        let map[152]=0; let map[153]=0; let map[154]=1; let map[155]=0;
