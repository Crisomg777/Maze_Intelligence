        // Fila 10
        let map[200]=1; let map[201]=1; let map[202]=1; let map[203]=1;
        let map[204]=0; let map[205]=1; let map[206]=0; let map[207]=0;
        let map[208]=0; let map[209]=0; let map[210]=1; let map[211]=1;
        let map[212]=0; let map[213]=0; let map[214]=0; let map[215]=1;
        let map[216]=0; let map[217]=1; let map[218]=0; let map[219]=1;

        // Fila 11
        let map[220]=1; let map[221]=0; let map[222]=0; let map[223]=1;
