        let map[252]=0; let map[253]=1; let map[254]=0; let map[255]=0;
        let map[256]=0; let map[257]=1; let map[258]=0; let map[259]=1;

        // Fila 13
        let map[260]=1; let map[261]=0; let map[262]=0; let map[263]=0;
        let map[264]=0; let map[265]=1; let map[266]=0; let map[267]=0;
